{
  "name": "budgetvault",
  "version": "1.0.0",
  "description": "Privacy-first local budget tracker — zero network calls, all data on-device",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "expo": "~57.0.2",
    "expo-crypto": "^57.0.0",
    "expo-document-picker": "^57.0.0",
    "expo-file-system": "^57.0.0",
    "expo-local-authentication": "^57.0.0",
    "expo-notifications": "^57.0.3",
    "expo-router": "^57.0.3",
    "expo-sharing": "^57.0.2",
    "expo-sqlite": "^57.0.0",
    "expo-status-bar": "~57.0.0",
    "pako": "^3.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-svg": "^15.15.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/pako": "^2.0.4",
    "@types/react": "~19.2.2",
    "better-sqlite3": "^12.11.1",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "check-privacy": "bash scripts/check-privacy.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 40
      }
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/types/**",
      "!src/auth/**",
      "!src/backup/**",
      "!src/notifications/**",
      "!src/theme/**",
      "!src/import/pdfExtract.ts",
      "!src/import/parsers/xlsxParser.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "private": true
}
